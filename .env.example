# ─────────────────────────────────────────────
#  Alini Solutions — Environment Variables
#  Copy this to .env.local and fill in values.
#  NEVER commit .env.local to git.
# ─────────────────────────────────────────────

# ── MySQL (CyberPanel) ──────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=alini_web
DB_USER=alini_user
DB_PASSWORD=YOUR_STRONG_DB_PASSWORD

# ── Admin Auth ──────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=YOUR_LONG_RANDOM_SECRET_HERE
JWT_EXPIRES_IN=8h

# ── Site ────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://alinisolution.co.ke
NEXT_PUBLIC_SITE_NAME=Alini Solutions

# ── Email (contact form notifications) ──────
SMTP_HOST=mail.alinisolution.co.ke
SMTP_PORT=587
SMTP_USER=hello@alinisolution.co.ke
SMTP_PASS=YOUR_EMAIL_PASSWORD
NOTIFY_EMAIL=hello@alinisolution.co.ke

# ── PM2 / Node ──────────────────────────────
PORT=3000
NODE_ENV=production
